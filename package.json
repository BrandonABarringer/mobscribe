{
	"name": "mobscribe",
	"version": "2.0.0",
	"type": "module",
	"description": "Real-time meeting transcription MCP server for Claude Code",
	"scripts": {
		"build": "tsc",
		"dev": "node --loader ts-node/esm src/index.ts",
		"start": "node dist/index.js",
		"record": "node dist/record.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "biome check --write .",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"knip": "knip",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,json,md}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"keywords": [],
	"author": "Brandon Barringer",
	"license": "ISC",
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"assemblyai": "^4.28.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/node": "^25.5.0",
		"esbuild": "^0.27.4",
		"husky": "^9.1.7",
		"knip": "^5.87.0",
		"lint-staged": "^16.4.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	}
}
